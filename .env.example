# LLM provider: "groq" (free tier — default) or "claude" (Haiku, costs money)
LLM_PROVIDER=groq
LLM_MAX_TOKENS=1024

# Groq (free tier) — get a key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Anthropic / Claude (optional — only if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# Telegram bot — get a token from @BotFather
TELEGRAM_BOT_TOKEN=
RATE_LIMIT_PER_DAY=5

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=anticensorship_handbook

# Retrieval
TOP_K=5
LOG_LEVEL=INFO
